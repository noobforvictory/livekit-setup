LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_AGENT_NAME=my-agent

# Your Telnyx-owned caller ID in +E.164 format.
TELNYX_PHONE_NUMBER=+15555550100

# Telnyx outbound SIP credentials from the Telnyx FQDN connection.
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=

# Trial accounts can only call the verified destination number.
TELNYX_TEST_DESTINATION=+15555550199

# Fill this after creating the outbound trunk.
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
